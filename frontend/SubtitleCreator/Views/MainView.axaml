<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SubtitleCreator.ViewModels"
             xmlns:views="clr-namespace:SubtitleCreator.Views"
             x:Class="SubtitleCreator.Views.MainView"
             x:DataType="vm:MainViewModel">

  <DockPanel LastChildFill="True" Margin="16">

    <StackPanel DockPanel.Dock="Top" Spacing="10" Margin="0 0 0 16">

      <TextBlock Text="Subtitle Creator" FontSize="22" FontWeight="Bold"/>

      <!-- Warning banner -->
      <Border Background="#7F3000" CornerRadius="4" Padding="10 6"
              IsVisible="{Binding WarningMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <TextBlock Text="{Binding WarningMessage}" Foreground="#FFB347" TextWrapping="Wrap"/>
      </Border>

      <!-- File input -->
      <Grid ColumnDefinitions="*,Auto">
        <Border Grid.Column="0"
                BorderBrush="Gray" BorderThickness="1" CornerRadius="4"
                DragDrop.AllowDrop="True" Background="Transparent"
                x:Name="DropZone">
          <TextBox PlaceholderText="Drop a video file here or browse…"
                   Text="{Binding SelectedFilePath}"
                   BorderThickness="0" Background="Transparent"/>
        </Border>
        <Button Grid.Column="1" Margin="8 0 0 0" Content="Browse" Click="OnBrowseClicked"/>
      </Grid>

      <!-- Action buttons -->
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="🇬🇧  English Subtitles"
                Command="{Binding StartEnglishCommand}"/>
        <Button Content="🇮🇱  Hebrew Subtitles"
                Command="{Binding StartHebrewCommand}"/>
      </StackPanel>

      <TextBlock Text="Any language → synced .srt" Foreground="Gray" FontSize="12"/>

    </StackPanel>

    <!-- Job detail -->
    <ContentControl Content="{Binding CurrentJob}">
      <ContentControl.DataTemplates>
        <DataTemplate x:DataType="vm:JobViewModel">
          <views:JobView/>
        </DataTemplate>
      </ContentControl.DataTemplates>
    </ContentControl>

  </DockPanel>
</UserControl>
