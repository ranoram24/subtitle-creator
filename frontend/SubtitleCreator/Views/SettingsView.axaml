<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SubtitleCreator.ViewModels"
             x:Class="SubtitleCreator.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             MaxWidth="600" Margin="24">

  <StackPanel Spacing="16">

    <TextBlock Text="Settings" FontSize="20" FontWeight="Bold"/>

    <!-- Python executable override -->
    <StackPanel Spacing="4">
      <TextBlock Text="Python executable (leave blank to auto-detect)"/>
      <TextBox Text="{Binding PythonExeOverride}"
               PlaceholderText="e.g. C:\Python311\python.exe"/>
    </StackPanel>

    <!-- Output directory override -->
    <StackPanel Spacing="4">
      <TextBlock Text="Output directory (leave blank to save next to source video)"/>
      <TextBox Text="{Binding OutputDirectoryOverride}"
               PlaceholderText="e.g. C:\Subtitles"/>
    </StackPanel>

    <!-- Device preference -->
    <StackPanel Spacing="4">
      <TextBlock Text="Inference device"/>
      <ComboBox ItemsSource="{Binding DeviceOptions}"
                SelectedItem="{Binding PreferredDevice}"
                Width="160"/>
    </StackPanel>

    <!-- Actions -->
    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Content="Save" Command="{Binding SaveCommand}"/>
      <Button Content="Reset to defaults" Command="{Binding ResetCommand}"/>
    </StackPanel>

    <TextBlock Text="{Binding StatusMessage}" Foreground="#4CAF50"
               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

  </StackPanel>
</UserControl>
