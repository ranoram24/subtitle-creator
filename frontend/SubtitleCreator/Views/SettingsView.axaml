<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SubtitleCreator.ViewModels"
             x:Class="SubtitleCreator.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             MaxWidth="560" Margin="24">

  <StackPanel Spacing="20">

    <TextBlock Text="Settings" FontSize="20" FontWeight="Bold"/>

    <!-- OpenAI API Key -->
    <StackPanel Spacing="6">
      <TextBlock Text="OpenAI API Key" FontWeight="SemiBold"/>
      <TextBlock Foreground="Gray" FontSize="12" TextWrapping="Wrap"
                 Text="Get your key at platform.openai.com → API keys. Transcription costs ~$0.006/min."/>
      <TextBox Text="{Binding OpenAiApiKey}"
               PlaceholderText="sk-..."
               PasswordChar="●"/>
    </StackPanel>

    <!-- Python override -->
    <StackPanel Spacing="4">
      <TextBlock Text="Python executable (leave blank for auto-detect)" Foreground="Gray" FontSize="12"/>
      <TextBox Text="{Binding PythonExeOverride}"
               PlaceholderText="e.g. C:\Python311\python.exe"/>
    </StackPanel>

    <Button Content="Save" Command="{Binding SaveCommand}" Width="80" HorizontalAlignment="Left"/>

    <TextBlock Text="{Binding StatusMessage}" Foreground="#4CAF50"
               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

  </StackPanel>
</UserControl>
