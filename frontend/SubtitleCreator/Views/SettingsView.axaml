<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SubtitleCreator.ViewModels"
             x:Class="SubtitleCreator.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             MaxWidth="560" Margin="24">

  <StackPanel Spacing="20">

    <TextBlock Text="Settings" FontSize="20" FontWeight="Bold"/>

    <!-- Theme -->
    <StackPanel Spacing="6">
      <TextBlock Text="Theme" FontWeight="SemiBold"/>
      <ComboBox ItemsSource="{x:Static vm:SettingsViewModel.ThemeOptions}"
                SelectedItem="{Binding SelectedTheme}"
                Width="200" HorizontalAlignment="Left"/>
    </StackPanel>

    <!-- Output directory -->
    <StackPanel Spacing="6">
      <TextBlock Text="Save subtitles to" FontWeight="SemiBold"/>
      <TextBlock Foreground="Gray" FontSize="12"
                 Text="Leave blank to save next to the video file."/>
      <Grid ColumnDefinitions="*,Auto">
        <TextBox Grid.Column="0"
                 Text="{Binding OutputDirectory}"
                 PlaceholderText="Same folder as video (default)"/>
        <Button Grid.Column="1" Margin="8 0 0 0" Content="Browse"
                Click="OnBrowseOutputDirClicked"/>
      </Grid>
    </StackPanel>

    <Button Content="Save" Command="{Binding SaveCommand}" Width="80" HorizontalAlignment="Left"/>

    <TextBlock Text="{Binding StatusMessage}" Foreground="#4CAF50"
               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

  </StackPanel>
</UserControl>
