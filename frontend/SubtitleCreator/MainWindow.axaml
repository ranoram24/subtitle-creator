<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SubtitleCreator.Views"
        xmlns:vm="clr-namespace:SubtitleCreator.ViewModels"
        x:Class="SubtitleCreator.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Subtitle Creator"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500">

  <TabControl>
    <TabItem Header="Subtitles">
      <views:MainView DataContext="{Binding Main}"/>
    </TabItem>
    <TabItem Header="Settings">
      <views:SettingsView DataContext="{Binding Settings}"/>
    </TabItem>
  </TabControl>

</Window>
